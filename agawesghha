local function mutarSom(som)
    if som:IsA("Sound") then
        som.Volume = 0
        som:Stop()
    end
end

local function mutarDescendentes(instancia)
    for _, obj in ipairs(instancia:GetDescendants()) do
        mutarSom(obj)
    end
end


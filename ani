    b.TextSize = 13
    Instance.new("UICorner", b).CornerRadius = UDim.new(0,5)

    b.MouseButton1Click:Connect(function()
        Click:Play()
        resetAnimations()
        
        -- Update all indicators
        for _, child in pairs(Scrolling:GetChildren()) do
            if child:IsA("Frame") and child:FindFirstChildWhichIsA("Frame") then
                local ind = child:FindFirstChildWhichIsA("Frame")
                if ind then
                    ind.BackgroundColor3 = Color3.fromRGB(80,80,80)
                end
            end
        end
    end)
    
    y += 44
end


-- Save original animations
local function saveOriginalAnimations()
    local char = Player.Character
    if not char then return end
    
    animateScript = char:FindFirstChild("Animate")
    if not animateScript then return end
    
    originalAnimIds = {
        idle1 = animateScript.idle and animateScript.idle.Animation1 and animateScript.idle.Animation1.AnimationId or nil,
        idle2 = animateScript.idle and animateScript.idle.Animation2 and animateScript.idle.Animation2.AnimationId or nil,
        walk = animateScript.walk and animateScript.walk.WalkAnim and animateScript.walk.WalkAnim.AnimationId or nil,
        run = animateScript.run and animateScript.run.RunAnim and animateScript.run.RunAnim.AnimationId or nil,
        jump = animateScript.jump and animateScript.jump.JumpAnim and animateScript.jump.JumpAnim.AnimationId or nil,
        fall = animateScript.fall and animateScript.fall.FallAnim and animateScript.fall.FallAnim.AnimationId or nil,
        climb = animateScript.climb and animateScript.climb.ClimbAnim and animateScript.climb.ClimbAnim.AnimationId or nil,
    }
end

-- Apply animation pack
local function applyAnimPack(animPack)
    if not Player.Character then return end
    
    local char = Player.Character
    animateScript = char:FindFirstChild("Animate")
    if not animateScript then return end
    
    -- Disable animate to prevent conflicts
    animateScript.Disabled = true
    task.wait(0.05)
    
    -- Apply new animations
    if animPack.idle1 then
        pcall(function()
            animateScript.idle.Animation1.AnimationId = animPack.idle1
        end)
    end
    if animPack.idle2 then
        pcall(function()
            animateScript.idle.Animation2.AnimationId = animPack.idle2
        end)
    end
    if animPack.walk then
        pcall(function()
            animateScript.walk.WalkAnim.AnimationId = animPack.walk
        end)
    end
    if animPack.run then
        pcall(function()
            animateScript.run.RunAnim.AnimationId = animPack.run
        end)
    end
    if animPack.jump then
        pcall(function()
            animateScript.jump.JumpAnim.AnimationId = animPack.jump
        end)
    end
    if animPack.fall then
        pcall(function()
            animateScript.fall.FallAnim.AnimationId = animPack.fall
        end)
    end
    if animPack.climb then
        pcall(function()
            animateScript.climb.ClimbAnim.AnimationId = animPack.climb
        end)
    end
    
    -- Re-enable animate
    animateScript.Disabled = false
    
    -- Refresh character state
    if Humanoid then
        Humanoid:ChangeState(Enum.HumanoidStateType.Running)
    end
end

-- Reset to original animations
local function resetAnimations()
    if not Player.Character then return end
    
    local char = Player.Character
    animateScript = char:FindFirstChild("Animate")
    if not animateScript then return end
    
    animateScript.Disabled = true
    task.wait(0.05)
    
    if originalAnimIds.idle1 then
        pcall(function() animateScript.idle.Animation1.AnimationId = originalAnimIds.idle1 end)
    end
    if originalAnimIds.idle2 then
        pcall(function() animateScript.idle.Animation2.AnimationId = originalAnimIds.idle2 end)
    end
    if originalAnimIds.walk then
        pcall(function() animateScript.walk.WalkAnim.AnimationId = originalAnimIds.walk end)
    end
    if originalAnimIds.run then
        pcall(function() animateScript.run.RunAnim.AnimationId = originalAnimIds.run end)
    end
    if originalAnimIds.jump then
        pcall(function() animateScript.jump.JumpAnim.AnimationId = originalAnimIds.jump end)
    end
    if originalAnimIds.fall then
        pcall(function() animateScript.fall.FallAnim.AnimationId = originalAnimIds.fall end)
    end
    if originalAnimIds.climb then
        pcall(function() animateScript.climb.ClimbAnim.AnimationId = originalAnimIds.climb end)
    end
    
    animateScript.Disabled = false
    
    if Humanoid then
        Humanoid:ChangeState(Enum.HumanoidStateType.Running)
    end
    
    currentAnimPack = nil
end


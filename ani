-- Button creation functions
local function AddAnimButton(animKey, animData)
    local f = Instance.new("Frame", Scrolling)
    f.Size = UDim2.new(1,0,0,38)
    f.Position = UDim2.new(0,0,0,y)
    f.BackgroundTransparency = 1

    local b = Instance.new("TextButton", f)
    b.Size = UDim2.new(1,0,1,0)
    b.BackgroundColor3 = Color3.fromRGB(38,35,55)
    b.Text = animData.name
    b.TextColor3 = Color3.new(1,1,1)
    b.Font = Enum.Font.GothamSemibold
    b.TextSize = 13
    Instance.new("UICorner", b).CornerRadius = UDim.new(0,5)

    local indicator = Instance.new("Frame", f)
    indicator.Size = UDim2.new(0,12,0,12)
    indicator.Position = UDim2.new(1,-20,0.5,-6)
    indicator.BackgroundColor3 = currentAnimPack == animKey and Color3.fromRGB(0,255,0) or Color3.fromRGB(80,80,80)
    Instance.new("UICorner", indicator).CornerRadius = UDim.new(0,6)

    b.MouseButton1Click:Connect(function()
        Click:Play()
        applyAnimPack(animData)
        currentAnimPack = animKey
        
        -- Update all indicators
        for _, child in pairs(Scrolling:GetChildren()) do
            if child:IsA("Frame") and child:FindFirstChildWhichIsA("Frame") then
                local ind = child:FindFirstChildWhichIsA("Frame")
                if ind and ind ~= indicator then
                    ind.BackgroundColor3 = Color3.fromRGB(80,80,80)
                end
            end
        end
        indicator.BackgroundColor3 = Color3.fromRGB(0,255,0)
    end)
    
    y += 44
end

local function AddResetButton()
    local f = Instance.new("Frame", Scrolling)
    f.Size = UDim2.new(1,0,0,38)
    f.Position = UDim2.new(0,0,0,y)
    f.BackgroundTransparency = 1

    local b = Instance.new("TextButton", f)
    b.Size = UDim2.new(1,0,1,0)
    b.BackgroundColor3 = Color3.fromRGB(75,45,55)
    b.Text = "🔄 Reset to Default"
